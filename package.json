{
  "author": "SiegeSailor",
  "bin": {
    "@siegesailor/cryptography": "./build/command.js"
  },
  "bugs": {
    "url": "https://github.com/SiegeSailor/cryptography/issues"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "inquirer": "13.3.2",
    "nanospinner": "1.2.2"
  },
  "description": "Provide a collection of cryptography functions and a CLI.",
  "devDependencies": {
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "11.0.6",
    "@semantic-release/npm": "12.0.2",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "jest": "30.3.0",
    "semantic-release": "24.2.9",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">= 25.2.1",
    "npm": ">= 11.6.2"
  },
  "files": [
    "./build/**/*"
  ],
  "homepage": "https://github.com/SiegeSailor/cryptography#readme",
  "keywords": [
    "command-line-tool",
    "cryptography",
    "typescript",
    "webassembly"
  ],
  "license": "ISC",
  "main": "./build/source/entry-point.js",
  "types": "./build/source/entry-point.d.ts",
  "exports": {
    ".": {
      "types": "./build/source/entry-point.d.ts",
      "default": "./build/source/entry-point.js"
    },
    "./package.json": "./package.json"
  },
  "name": "@siegesailor/cryptography",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SiegeSailor/cryptography.git"
  },
  "scripts": {
    "clean-workspace-files": "rm -rf ./build ./build-cache",
    "run-cli-typescript": "clear && ts-node -r tsconfig-paths/register ./source/command.ts",
    "run-cli-compiled": "node ./build/command.js",
    "test-unit-suite": "jest",
    "build-webassembly-binaries": "node ./scripts/compile-wasm.js",
    "build-webassembly-strict": "WASM_STRICT=1 node ./scripts/compile-wasm.js",
    "verify-webassembly-runtime": "node ./scripts/verify-wasm.js",
    "build-typescript-output": "tsc && npx --no-install tsc-alias",
    "build-webassembly-assets": "node ./scripts/copy-wasm.js",
    "dev:clean": "npm run clean-workspace-files",
    "dev:run": "npm run run-cli-typescript",
    "dev:run-compiled": "npm run run-cli-compiled",
    "dev:test": "npm run test-unit-suite",
    "dev:test-wasm": "npm run build-webassembly-strict && npm run verify-webassembly-runtime && npm run test-unit-suite -- --runInBand",
    "dev:build": "npm run build-webassembly-binaries && npm run build-typescript-output && npm run build-webassembly-assets",
    "ci:install": "npm ci",
    "ci:test": "npm run test-unit-suite -- --ci --runInBand --verbose --coverage",
    "ci:build": "npm run build-webassembly-binaries && npm run build-typescript-output && npm run build-webassembly-assets",
    "ci:verify": "npm run ci:test && npm run ci:build",
    "ci:publish": "semantic-release",
    "ci:release": "semantic-release"
  },
  "version": "1.0.0"
}
