{
  "author": "SiegeSailor",
  "bin": {
    "formulas": "./build/command.js"
  },
  "bugs": {
    "url": "https://github.com/SiegeSailor/formulas/issues"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "inquirer": "^8.2.6",
    "nanospinner": "^1.2.2"
  },
  "description": "Provide a collection of formula functions and a command line tool.",
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wabt": "^1.0.37"
  },
  "engines": {
    "node": ">= 20.0.0",
    "npm": ">= 10.0.0"
  },
  "files": [
    "./build/**/*"
  ],
  "homepage": "https://github.com/SiegeSailor/formulas#readme",
  "keywords": [
    "typescript",
    "command-line-tool",
    "package"
  ],
  "license": "ISC",
  "main": "./build/source/entry-point.js",
  "types": "./build/source/entry-point.d.ts",
  "exports": {
    ".": {
      "types": "./build/source/entry-point.d.ts",
      "default": "./build/source/entry-point.js"
    },
    "./package.json": "./package.json"
  },
  "name": "formulas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SiegeSailor/formulas.git"
  },
  "scripts": {
    "build": "npm run wasm:compile && npm run test && tsc && npm run wasm:copy",
    "start": "clear && ts-node ./source/command.ts",
    "start:build": "node ./build/command.js",
    "test": "jest",
    "wasm:compile": "node ./scripts/compile-wasm.js",
    "wasm:copy": "node ./scripts/copy-wasm.js",
    "prepack": "npm run build"
  },
  "version": "1.0.0"
}
